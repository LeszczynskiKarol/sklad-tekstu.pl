// Raw LaTeX code for the before/after demo
const rawLatexCode = `<span class="t-cmd">\\section</span><span class="t-brace">{Analiza wyników}</span>\n\nWyniki eksperymentu potwierdzają\nhipotezę. Współczynnik korelacji\n<span class="t-cmd">\\(</span>r = 0.847<span class="t-cmd">\\)</span> wskazuje na\nsilną zależność liniową.\n\nRozkład próby opisuje wzór:\n<span class="t-cmd">\\[</span>\n  f(x) = <span class="t-cmd">\\frac</span><span class="t-brace">{1}</span><span class="t-brace">{\\sigma\\sqrt{2\\pi}}</span>\n  e^<span class="t-brace">{-\\frac{1}{2}(\\frac{x-\\mu}{\\sigma})^2}</span>\n<span class="t-cmd">\\]</span>`;

// Hero watermark code
const heroWatermark = `\\documentclass[12pt]{article}\n\\usepackage[T1]{fontenc}\n\\usepackage{lmodern}\n\\usepackage[polish]{babel}\n\\usepackage{microtype}\n\\begin{document}\n\\maketitle`;
---

<BaseLayout
  title="Skład tekstu i łamanie do druku — książki, prace, publikacje"
  description="Profesjonalny skład i łamanie tekstu — książki, prace naukowe, podręczniki, katalogi i dokumenty techniczne. Przygotowanie plików do druku (DTP) z typografią klasy wydawniczej."
  keywords="skład tekstu, łamanie tekstu, skład książki, skład do druku, przygotowanie do druku, DTP, skład pracy doktorskiej, skład publikacji, skład prac naukowych, skład podręcznika, skład tekstu latex"
  schema={homeSchema}
>

  <!-- ════════════════════════════════════════════════
       HERO — Title page
       ════════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero__code" aria-hidden="true">
      <pre set:html={heroWatermark} />
    </div>

    <div class="container hero__inner">
      <div class="hero__rule-top" aria-hidden="true"></div>

      <h1 id="hero-title" class="hero__title">
        Profesjonalny <span class="hero__highlight">skład i&nbsp;łamanie tekstu</span><br>
        do&nbsp;druku i&nbsp;publikacji
      </h1>

      <p class="hero__subtitle">
        Składamy książki, prace naukowe, podręczniki, katalogi i&nbsp;dokumenty<br>
        techniczne — z&nbsp;perfekcyjną typografią i&nbsp;przygotowaniem do&nbsp;druku
      </p>

      <p class="hero__meta" set:html="\\documentclass{perfection} &middot; wersja 2026 &middot; sklad-tekstu.pl" />

      <div class="hero__rule-bottom" aria-hidden="true"></div>

      <div class="hero__actions">
        <a href="#kontakt" class="hero__cta-primary">
          Wyślij tekst do wyceny
          <span class="hero__cta-arrow">→</span>
        </a>
        <a href="#uslugi" class="hero__cta-secondary">
          Zobacz usługi
        </a>
      </div>

      <div class="hero__trust">
        <span class="hero__trust-item">✓ Wycena w&nbsp;24 godz.</span>
        <span class="hero__trust-item">✓ Bez zobowiązań</span>
        <span class="hero__trust-item">✓ Jakość drukarska</span>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════
       BEFORE → AFTER TRANSFORMATION
       ════════════════════════════════════════════════ -->
  <section class="transform reveal" aria-label="Przykład transformacji tekstu">
    <div class="container-wide">
      <div class="transform__demo">
        <div class="transform__panel transform__panel--before">
          <div class="transform__label">Surowy tekst</div>
          <pre class="transform__raw" set:html={rawLatexCode} />
        </div>

        <div class="transform__arrow" aria-label="przekształca się w">
          <span>⟹</span>
        </div>

        <div class="transform__panel transform__panel--after">
          <div class="transform__label">Złożony dokument</div>
          <div class="transform__rendered">
            <h3>3. Analiza wyników</h3>
            <p>Wyniki eksperymentu potwierdzają hipotezę. Współczynnik korelacji <em>r</em>&nbsp;=&nbsp;0,847 wskazuje na silną zależność liniową.</p>
            <p>Rozkład próby opisuje wzór:</p>
            <span class="transform__math">
              <em>f</em>(<em>x</em>) = <sup>1</sup>&frasl;<sub>σ√2π</sub> · <em>e</em><sup>−½((x−μ)/σ)²</sup>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════
       §1 USŁUGI
       ════════════════════════════════════════════════ -->
  <section class="services" id="uslugi" aria-labelledby="uslugi-title">
    <div class="container">
      <div class="reveal">
        <SectionHeading
          number="§1"
          title="Usługi składu i&nbsp;publikacji"
          subtitle="Specjalizujemy się w profesjonalnym składzie tekstu LaTeX — od prac naukowych i podręczników akademickich, przez dokumentację techniczną, po katalogi produktowe i materiały korporacyjne. Każdy dokument traktujemy z typograficzną precyzją."
        />
      </div>
    </div>
    <div class="container-wide">
      <div class="services__grid reveal">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════
       §2 PROCES
       ════════════════════════════════════════════════ -->
  <section class="process" id="proces" aria-labelledby="proces-title">
    <div class="container">
      <div class="reveal">
        <SectionHeading
          number="§2"
          title="Proces realizacji"
          subtitle="Od surowego tekstu do gotowego PDF w jakości drukarskiej. Przejrzysty, przewidywalny proces, w którym zawsze wiesz, na jakim etapie jest Twój dokument."
        />
      </div>

      <div class="process__steps">
        {processSteps.map((step, i) => (
          <div class="process__step reveal">
            <div class="process__step-num" aria-hidden="true"></div>
            <div class="process__step-content">
              <h3 class="process__step-title">
                {step.title}
                <span class="process__step-latex">{step.latex}</span>
              </h3>
              <p class="process__step-desc">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

 <!-- ════════════════════════════════════════════════
       §3 REALIZACJE (showcase)
       ════════════════════════════════════════════════ -->
  <section class="showcase" id="realizacje" aria-labelledby="realizacje-title">
    <div class="container">
      <div class="reveal">
