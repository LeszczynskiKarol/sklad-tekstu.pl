    animation: fadeInUp 0.9s ease 1.3s forwards;
  }

  .hero__cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 2rem;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-serif);
    font-size: var(--fs-base);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .hero__cta-primary:hover {
    background: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(139, 26, 26, 0.2);
  }

  .hero__cta-arrow {
    transition: transform var(--transition-fast);
  }

  .hero__cta-primary:hover .hero__cta-arrow {
    transform: translateX(4px);
  }

  .hero__cta-secondary {
    font-family: var(--font-serif);
    font-size: var(--fs-base);
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: all var(--transition-fast);
  }

  .hero__cta-secondary:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  .hero__trust {
    display: flex;
    justify-content: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    margin-top: var(--space-8);
    opacity: 0;
    animation: fadeInUp 0.9s ease 1.5s forwards;
  }

  .hero__trust-item {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--ink-faint);
    letter-spacing: 0.03em;
  }

  /* ══════════════════════════════════════════════════
     TRANSFORM DEMO
     ══════════════════════════════════════════════════ */
  .transform {
    padding: 0 0 var(--space-20);
  }

  .transform__demo {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .transform__demo {
      grid-template-columns: 1fr;
    }
  }

  .transform__panel {
    padding: var(--space-8) var(--space-6);
  }

  .transform__label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .transform__label::after {
    content: '';
    flex: 1;
    height: 0.5px;
    background: var(--rule-light);
  }

  .transform__panel--before {
    background: #f7f5f0;
  }

  .transform__raw {
    font-family: 'Courier New', monospace;
    font-size: 0.78rem;
    line-height: 1.65;
    color: var(--ink-muted);
    white-space: pre-wrap;
    margin: 0;
  }

  .t-cmd { color: var(--accent); }
  .t-brace { color: var(--latex-blue); }

  .transform__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink);
    color: var(--paper);
    width: 50px;
    font-size: 1.3rem;
  }

  .transform__arrow span {
    animation: pulseArrow 2s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .transform__arrow {
      width: 100%;
      height: 40px;
    }
    .transform__arrow span::after {
      content: '⟱';
    }
    .transform__arrow span {
      font-size: 0;
    }
    .transform__arrow span::after {
      font-size: 1.3rem;
    }
  }

  .transform__panel--after {
    background: var(--white);
  }

  .transform__rendered h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: var(--fw-semibold);
    margin-bottom: 0.8rem;
  }

  .transform__rendered p {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: var(--lh-relaxed);
    text-align: justify;
    hyphens: auto;
    color: var(--ink-light);
    margin-bottom: 0.5rem;
  }

  .transform__math {
    display: block;
    text-align: center;
    margin: var(--space-4) 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink);
  }

  /* ══════════════════════════════════════════════════
     §1 SERVICES — 3×3 symmetric grid
     ══════════════════════════════════════════════════ */
  .services {
    padding: var(--space-12) 0 var(--space-20);
    background: linear-gradient(180deg, var(--paper) 0%, var(--paper-warm) 100%);
    border-top: 0.5px solid var(--rule-light);
    border-bottom: 0.5px solid var(--rule-light);
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ══════════════════════════════════════════════════
     §2 PROCESS
     ══════════════════════════════════════════════════ */
  .process {
    padding: var(--space-20) 0;
  }

  .process__steps {
    counter-reset: step;
  }

  .process__step {
    counter-increment: step;
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-8);
    padding: var(--space-6) 0;
    border-bottom: 0.5px solid var(--rule-light);
  }

  @media (max-width: 768px) {
    .process__step {
      grid-template-columns: 50px 1fr;
      gap: var(--space-4);
    }
  }

  .process__step-num {
    font-family: var(--font-display);
    font-size: var(--fs-4xl);
    font-weight: var(--fw-light);
    color: var(--rule);
    text-align: right;
    line-height: 1;
    padding-top: 0.3rem;
  }

  .process__step-num::before {
    content: counter(step) ".";
  }

  .process__step-title {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-lg);
    margin-bottom: var(--space-2);
    color: var(--ink);
  }

  .process__step-latex {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--ink-faint);
    font-weight: var(--fw-regular);
    margin-left: 0.8rem;
  }

  .process__step-desc {
    font-size: 0.92rem;
    line-height: var(--lh-relaxed);
    color: var(--ink-light);
    max-width: 580px;
  }

  /* ══════════════════════════════════════════════════
     §3 SHOWCASE
     ══════════════════════════════════════════════════ */
  .showcase {
    padding: var(--space-20) 0;
    background: var(--ink);
    position: relative;
    overflow: hidden;
  }

  .showcase::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .showcase__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    position: relative;
  }

  @media (max-width: 1024px) {
    .showcase__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .showcase__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .showcase__grid {
      grid-template-columns: 1fr;
      max-width: 320px;
      margin: 0 auto;
    }
  }

  .showcase__card {
    background: white;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    transition: transform 0.4s ease;
    cursor: pointer;
  }

  .showcase__card:hover {
    transform: translateY(-6px) scale(1.02);
  }

  .showcase__page {
    aspect-ratio: 210 / 297;
    padding: var(--space-6) var(--space-5);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .showcase__page-type {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: var(--space-3);
  }

  .showcase__page-title {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    line-height: 1.3;
    margin-bottom: var(--space-4);
  }

  .showcase__page-title small {
    display: block;
    font-weight: var(--fw-light);
    font-size: 0.72rem;
    color: var(--ink-muted);
    margin-top: 0.2rem;
  }

  .showcase__page-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .showcase__fake-line {
    height: 3px;
    background: var(--paper-dark);
    border-radius: 1px;
    width: 100%;
  }

  .showcase__fake-line.short { width: 75%; }

  .showcase__formula {
    margin: var(--space-3) 0;
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.7rem;
    color: var(--ink-light);
  }

  .showcase__placeholder {
    width: 100%;
    height: 50px;
    background: linear-gradient(135deg, var(--paper-dark) 0%, var(--rule-light) 100%);
    border-radius: 1px;
    margin: var(--space-2) 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--ink-faint);
  }

  .showcase__page-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 0.5px solid var(--rule-light);
  }

  .showcase__page-num {
    font-family: var(--font-serif);
    font-size: 0.65rem;
    color: var(--ink-faint);
  }

  .showcase__page-cta {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--accent);
    letter-spacing: 0.03em;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.3s ease;
  }

  .showcase__card:hover .showcase__page-cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* ══════════════════════════════════════════════════
     PDF MODAL
     ══════════════════════════════════════════════════ */
  .pdf-modal {
    position: fixed;
    inset: 0;
    z-index: 10001;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .pdf-modal[hidden] { display: none; }

  .pdf-modal.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .pdf-modal__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(26, 26, 26, 0.85);
    backdrop-filter: blur(4px);
  }

  .pdf-modal__container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--space-4);
  }

  @media (max-width: 768px) {
    .pdf-modal__container {
      padding: var(--space-2);
    }
  }

  .pdf-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--paper);
    border-bottom: 2px solid var(--ink);
    flex-shrink: 0;
  }

  .pdf-modal__type {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .pdf-modal__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: var(--fw-semibold);
    color: var(--ink);
    margin: 2px 0;
    line-height: 1.2;
  }

  .pdf-modal__subtitle {
    font-family: var(--font-serif);
    font-size: 0.75rem;
    font-style: italic;
    color: var(--ink-muted);
  }

  .pdf-modal__controls {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .pdf-modal__nav,
  .pdf-modal__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--paper-warm);
    border: 0.5px solid var(--rule-light);
    color: var(--ink-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .pdf-modal__nav:hover,
  .pdf-modal__close:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .pdf-modal__counter {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--ink-faint);
    min-width: 40px;
    text-align: center;
  }

  .pdf-modal__close {
    margin-left: var(--space-2);
    background: var(--ink);
    color: var(--paper);
  }

  .pdf-modal__close:hover {
    background: var(--accent);
  }

  .pdf-modal__viewer {
    flex: 1;
    position: relative;
    background: #525659;
    min-height: 0;
  }

  .pdf-modal__iframe {
    width: 100%;
    height: 100%;
    border: none;
    transition: opacity 0.3s ease;
  }

  .pdf-modal__loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--rule);
    letter-spacing: 0.05em;
  }

  .pdf-modal__spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--rule);
    border-top-color: var(--paper);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }


  /* ══════════════════════════════════════════════════
     §4 WHY LATEX
     ══════════════════════════════════════════════════ */
  .why {
    padding: var(--space-20) 0;
  }

  .why__grid {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 0;
  }

  @media (max-width: 768px) {
    .why__grid {
      grid-template-columns: 1fr;
    }
  }

  .why__item {
    display: contents;
  }

  .why__label {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--margin-note);
    text-align: right;
    padding-top: var(--space-1);
    padding-right: var(--space-8);
    letter-spacing: 0.04em;
  }

  @media (max-width: 768px) {
    .why__label {
      text-align: left;
      padding-right: 0;
      margin-bottom: var(--space-1);
    }
  }

  .why__content {
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-4);
    border-bottom: 0.5px solid var(--rule-light);
  }

  .why__content h3 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--fw-semibold);
    margin-bottom: var(--space-2);
    color: var(--ink);
  }

  .why__content p {
    font-size: 0.92rem;
    line-height: var(--lh-relaxed);
    color: var(--ink-light);
    text-align: justify;
    hyphens: auto;
  }

  /* ══════════════════════════════════════════════════
     §5 BLOG SECTION
     ══════════════════════════════════════════════════ */
  .blog-section {
    padding: var(--space-20) 0;
    background: var(--paper-warm);
    border-top: 0.5px solid var(--rule);
    border-bottom: 0.5px solid var(--rule);
  }

  .blog-section__posts {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .blog-section__card {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: var(--space-6);
    padding: var(--space-8) 0;
    border-bottom: 0.5px solid var(--rule-light);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .blog-section__card:first-child {
    border-top: 1px solid var(--ink);
  }

  .blog-section__card:hover {
    padding-left: var(--space-4);
    background: var(--paper);
    margin: 0 calc(-1 * var(--space-4));
    padding-right: var(--space-4);
  }

  @media (max-width: 640px) {
    .blog-section__card {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }

  .blog-section__card-number {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    font-weight: var(--fw-light);
    color: var(--rule);
    line-height: 1;
    padding-top: 0.2rem;
    text-align: right;
  }

  @media (max-width: 640px) {
    .blog-section__card-number {
      font-size: var(--fs-xl);
      text-align: left;
    }
  }

  .blog-section__card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .blog-section__card-category {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .blog-section__card-date {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--ink-faint);
  }

  .blog-section__card-title {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-lg);
    line-height: var(--lh-tight);
    color: var(--ink);
    margin-bottom: var(--space-2);
    transition: color var(--transition-fast);
  }

  .blog-section__card:hover .blog-section__card-title {
    color: var(--accent);
  }

  .blog-section__card-desc {
    font-size: var(--fs-sm);
    color: var(--ink-muted);
    line-height: var(--lh-relaxed);
    max-width: 580px;
  }

  .blog-section__card-read {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--accent);
    margin-top: var(--space-3);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.3s ease;
  }

  .blog-section__card:hover .blog-section__card-read {
    opacity: 1;
    transform: translateX(0);
  }

  .blog-section__more {
    margin-top: var(--space-10);
    text-align: center;
  }

  .blog-section__more-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: var(--fs-base);
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: all var(--transition-fast);
  }

  .blog-section__more-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .blog-section__more-arrow {
    transition: transform var(--transition-fast);
  }

  .blog-section__more-link:hover .blog-section__more-arrow {
    transform: translateX(4px);
  }

  /* ══════════════════════════════════════════════════
     §6 CTA
     ══════════════════════════════════════════════════ */
  .cta {
    padding: var(--space-20) 0;
    background: var(--paper-warm);
    border-top: 0.5px solid var(--rule);
  }

  .cta__block {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .cta__env {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-6);
  }

  .cta__env:last-child {
    margin-bottom: 0;
    margin-top: var(--space-6);
  }

  .cta__block h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: var(--fw-semibold);
    margin-bottom: var(--space-4);
    line-height: var(--lh-tight);
  }

  .cta__block p {
    font-size: 0.95rem;
    color: var(--ink-light);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-8);
  }

  .cta__button {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 1rem 2.5rem;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-serif);
    font-size: var(--fs-base);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
  }

  .cta__button:hover {
    background: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(139, 26, 26, 0.2);
  }

  .cta__button-arrow {
    transition: transform var(--transition-fast);
  }

  .cta__button:hover .cta__button-arrow {
    transform: translateX(4px);
  }

  .cta__details {
    margin-top: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--ink-faint);
  }

  .cta__details a {
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .cta__details a:hover {
    color: var(--accent-hover);
  }

  /* ══════════════════════════════════════════════════
     SEO CONTENT
     ══════════════════════════════════════════════════ */
  .seo-content {
    padding: var(--space-20) 0;
